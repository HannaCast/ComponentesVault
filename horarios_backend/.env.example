# Configuraciones de la base de datos MySQL
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# Link del frontend
LINK_FRONTEND=http://localhost:5173

# Configuraciones de Django para el proyecto de generación de horarios académicos
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Llave privada RSA para desencriptar requests (usar una de las dos opciones)
RSA_PRIVATE_KEY=
RSA_PRIVATE_KEY_PATH=keys/private_key.pem

# Configuracion de correo SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=youremail@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=EduSchedule <youremail@example.com>

# Flujo de verificacion de cuenta
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

