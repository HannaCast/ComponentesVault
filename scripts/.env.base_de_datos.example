# Copia este archivo como .env.base_de_datos y llena tus credenciales locales.
# Ese archivo real NO debe subirse al repositorio.

# Ruta al ejecutable mysql (opcional)
MYSQL_BIN=mysql

# Conexion MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cdi_horarios

# Si DB_PASSWORD queda vacio, el script la pedira por consola.
