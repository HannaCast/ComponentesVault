@echo off
setlocal EnableExtensions EnableDelayedExpansion

:: ================================
:: CONFIGURACION (EDITAR ESTO)
:: ================================

:: Carpeta donde se almacenan los .sql de backups
set BACKUP_DIR=RUTA_AQUI_BACKUPS

:: Retencion en dias para copias viejas
set RETENTION_DAYS=30

:: ================================
:: VALIDACIONES
:: ================================

if "%BACKUP_DIR%"=="RUTA_AQUI_BACKUPS" (
    echo ERROR: Debes configurar BACKUP_DIR
    exit /b 1
)

if "%RETENTION_DAYS%"=="" (
    echo ERROR: Debes configurar RETENTION_DAYS
    exit /b 1
)

if not exist "%BACKUP_DIR%" (
    echo ERROR: BACKUP_DIR no existe: %BACKUP_DIR%
    exit /b 1
)

echo Eliminando backups .sql con mas de %RETENTION_DAYS% dias en "%BACKUP_DIR%"...

set DELETED_COUNT=0
for /f %%A in ('forfiles /P "%BACKUP_DIR%" /M horarios_*.sql /D -%RETENTION_DAYS% /C "cmd /c echo Eliminado: @file && del @path" ^| find /c "Eliminado:"') do set DELETED_COUNT=%%A

echo Limpieza completada. Backups eliminados: %DELETED_COUNT%
