#!/usr/bin/env bash
set -euo pipefail

# ================================
# CONFIGURACION (EDITAR ESTO)
# ================================

BACKUP_DIR="/RUTA/AQUI/BACKUPS"
RETENTION_DAYS=30

# ================================
# VALIDACIONES
# ================================

if [[ "$BACKUP_DIR" == "/RUTA/AQUI/BACKUPS" ]]; then
  echo "ERROR: Debes configurar BACKUP_DIR"
  exit 1
fi

if [[ -z "${RETENTION_DAYS:-}" ]]; then
  echo "ERROR: Debes configurar RETENTION_DAYS"
  exit 1
fi

if [[ ! -d "$BACKUP_DIR" ]]; then
  echo "ERROR: BACKUP_DIR no existe: $BACKUP_DIR"
  exit 1
fi

echo "Eliminando backups .sql con mas de $RETENTION_DAYS dias en $BACKUP_DIR..."

DELETED_COUNT=$(find "$BACKUP_DIR" -maxdepth 1 -type f -name 'horarios_*.sql' -mtime +"$RETENTION_DAYS" -print -delete | wc -l | tr -d ' ')

echo "Limpieza completada. Backups eliminados: $DELETED_COUNT"
