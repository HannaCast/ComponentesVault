@echo off
setlocal EnableExtensions EnableDelayedExpansion

:: ================================
:: CONFIGURACION (EDITAR ESTO)
:: ================================

:: Usuario de MySQL
set MYSQL_USER=REEMPLAZAR_USUARIO

:: Contrasena (opcional si usas my.ini o .cnf)
set MYSQL_PASSWORD=REEMPLAZAR_PASSWORD

:: Nombre de la base de datos
set DB_NAME=REEMPLAZAR_DB

:: Carpeta donde guardar backups
set BACKUP_DIR=REEMPLAZAR_RUTA_BACKUPS

:: Opcional: cambia estos ejecutables si no estan en PATH
set MYSQL_DUMP_BIN=mysqldump

:: ================================
:: VALIDACIONES
:: ================================

if "%MYSQL_USER%"=="REEMPLAZAR_USUARIO" (
    echo ERROR: Debes configurar MYSQL_USER
    exit /b 1
)

if "%DB_NAME%"=="REEMPLAZAR_DB" (
    echo ERROR: Debes configurar DB_NAME
    exit /b 1
)

if "%BACKUP_DIR%"=="REEMPLAZAR_RUTA_BACKUPS" (
    echo ERROR: Debes configurar BACKUP_DIR
    exit /b 1
)

if not exist "%BACKUP_DIR%" (
    mkdir "%BACKUP_DIR%"
)

:: ================================
:: AUTENTICACION MYSQL
:: ================================

set MYSQL_AUTH=-u %MYSQL_USER%
if not "%MYSQL_PASSWORD%"=="REEMPLAZAR_PASSWORD" (
    set MYSQL_AUTH=%MYSQL_AUTH% -p%MYSQL_PASSWORD%
)

:: ================================
:: CREACION DE LA COPIA COMPLETA
:: ================================

for /f %%I in ('powershell -NoProfile -Command "Get-Date -Format \"yyyy-MM-dd_HH-mm\""') do set DATE=%%I

set OUTPUT_FILE=%BACKUP_DIR%\horarios_full_%DATE%.sql

%MYSQL_DUMP_BIN% %MYSQL_AUTH% --single-transaction --routines --triggers %DB_NAME% > "%OUTPUT_FILE%"
if errorlevel 1 (
    echo ERROR: Fallo el respaldo completo.
    exit /b 1
)

echo Backup completo generado:
echo %OUTPUT_FILE%