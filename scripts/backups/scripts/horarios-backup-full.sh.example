#!/usr/bin/env bash
set -euo pipefail

# ================================
# CONFIGURACION (EDITAR ESTO)
# ================================

MYSQL_USER="REEMPLAZAR_USUARIO"
MYSQL_PASSWORD="REEMPLAZAR_PASSWORD"
DB_NAME="REEMPLAZAR_DB"
BACKUP_DIR="/REEMPLAZAR/RUTA/BACKUPS"

# Opcional: cambia estos ejecutables si no estan en PATH
MYSQL_DUMP_BIN="mysqldump"

# ================================
# VALIDACIONES
# ================================

if [[ "$MYSQL_USER" == "REEMPLAZAR_USUARIO" ]]; then
  echo "ERROR: Debes configurar MYSQL_USER"
  exit 1
fi

if [[ "$DB_NAME" == "REEMPLAZAR_DB" ]]; then
  echo "ERROR: Debes configurar DB_NAME"
  exit 1
fi

if [[ "$BACKUP_DIR" == "/REEMPLAZAR/RUTA/BACKUPS" ]]; then
  echo "ERROR: Debes configurar BACKUP_DIR"
  exit 1
fi

mkdir -p "$BACKUP_DIR"

# ================================
# AUTENTICACION MYSQL
# ================================

MYSQL_AUTH=(-u "$MYSQL_USER")
if [[ -n "$MYSQL_PASSWORD" && "$MYSQL_PASSWORD" != "REEMPLAZAR_PASSWORD" ]]; then
  MYSQL_AUTH+=(-p"$MYSQL_PASSWORD")
fi

# ================================
# CREACION DE LA COPIA COMPLETA
# ================================

DATE="$(date +'%Y-%m-%d_%H-%M')"
OUTPUT_FILE="$BACKUP_DIR/horarios_full_${DATE}.sql"

"$MYSQL_DUMP_BIN" "${MYSQL_AUTH[@]}" --single-transaction --routines --triggers "$DB_NAME" > "$OUTPUT_FILE"

echo "Backup completo generado:"
echo "$OUTPUT_FILE"
