@echo off

:: ================================
:: CONFIGURACIÓN (EDITAR ESTO)
:: ================================

:: Directorio donde se guardarán los backups
set BACKUP_DIR=RUTA_AQUI_BACKUPS

:: Directorio donde MySQL guarda los binlogs
set BINLOG_DIR=RUTA_AQUI_BINLOGS

:: Credenciales de MySQL
set MYSQL_USER=TU_USUARIO
set MYSQL_PASSWORD=TU_PASSWORD

:: Archivo para tracking de binlogs
set LOG_TRACK_FILE=%BACKUP_DIR%\ultimo_binlog.txt



:: Generar una fecha válida para los respaldos
for /f "tokens=2 delims==" %%I in ('wmic os get localdatetime /value ^| find "="') do set datetime=%%I
set DATE=%datetime:~0,4%-%datetime:~4,2%-%datetime:~6,2%_%datetime:~8,2%-%datetime:~10,2%
set DATE=%DATE::=-%

:: Leer último binlog y posición respaldada
set LAST_BINLOG=
set LAST_POSITION=
if exist "%LOG_TRACK_FILE%" (
    for /f "tokens=1,2 delims=," %%A in (%LOG_TRACK_FILE%) do (
        set "LAST_BINLOG=%%A"
        set "LAST_POSITION=%%B"
    )
    echo Último binlog respaldado: %LAST_BINLOG% en la posición %LAST_POSITION%.
) else (
    echo No se encontró un registro previo de binlogs respaldados.
)

:: Obtener el binlog actual
mysql -u %MYSQL_USER% -p%MYSQL_PASSWORD% -e "SHOW MASTER STATUS;" > %BACKUP_DIR%\master_status.txt

:: Procesar el archivo master_status.txt para obtener binlog y posición
for /f "skip=1 tokens=1,2 delims=	" %%A in (%BACKUP_DIR%\master_status.txt) do (
    set "CURRENT_BINLOG=%%A"
    set "CURRENT_POSITION=%%B"
    goto :continue
)

:continue
:: Limpiar espacios adicionales en las variables (si los hay)
set "CURRENT_BINLOG=%CURRENT_BINLOG: =%"
set "CURRENT_POSITION=%CURRENT_POSITION: =%"

echo Binlog actual: %CURRENT_BINLOG%, posición: %CURRENT_POSITION%.

:: Respaldo incremental
if "%LAST_BINLOG%"=="" (
    echo Entrando en caso: No hay un binlog previo respaldado.
    mysqlbinlog "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%BACKUP_DIR%\horarios_incremental_%DATE%.sql"
    echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
) else (
    if "%LAST_BINLOG%"=="%CURRENT_BINLOG%" (
        echo Entrando en caso: Respaldo incremental desde la posición %LAST_POSITION%.
        mysqlbinlog --start-position=%LAST_POSITION% "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%BACKUP_DIR%\horarios_incremental_%DATE%.sql"
        echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
    ) else (
        echo Entrando en caso: Nuevo binlog detectado.
        mysqlbinlog "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%BACKUP_DIR%\horarios_incremental_%DATE%.sql"
        echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
    )
)

:: Mostrar la ruta utilizada para mysqlbinlog
echo Ruta del binlog procesado: "%BINLOG_DIR%\%CURRENT_BINLOG%"
echo Respaldo incremental completado.
pause