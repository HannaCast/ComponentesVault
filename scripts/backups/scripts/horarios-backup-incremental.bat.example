@echo off
setlocal EnableExtensions EnableDelayedExpansion

:: ================================
:: CONFIGURACIÓN (EDITAR ESTO)
:: ================================

:: Directorio donde se guardarán los backups
set BACKUP_DIR=RUTA_AQUI_BACKUPS

:: Directorio donde MySQL guarda los binlogs
set BINLOG_DIR=RUTA_AQUI_BINLOGS

:: Credenciales de MySQL
set MYSQL_USER=TU_USUARIO
set MYSQL_PASSWORD=TU_PASSWORD

:: Opcional: cambia estos ejecutables si no estan en PATH
set MYSQL_CLI_BIN=mysql
set MYSQL_BINLOG_BIN=mysqlbinlog

:: Archivo para tracking de binlogs
set LOG_TRACK_FILE=%BACKUP_DIR%\ultimo_binlog.txt
set MASTER_STATUS_FILE=%BACKUP_DIR%\master_status_incremental.txt

:: ================================
:: VALIDACIONES
:: ================================

if "%MYSQL_USER%"=="TU_USUARIO" (
    echo ERROR: Debes configurar MYSQL_USER
    exit /b 1
)

if "%BACKUP_DIR%"=="RUTA_AQUI_BACKUPS" (
    echo ERROR: Debes configurar BACKUP_DIR
    exit /b 1
)

if "%BINLOG_DIR%"=="RUTA_AQUI_BINLOGS" (
    echo ERROR: Debes configurar BINLOG_DIR
    exit /b 1
)

if not exist "%BACKUP_DIR%" (
    mkdir "%BACKUP_DIR%"
)

if not exist "%BINLOG_DIR%" (
    echo ERROR: BINLOG_DIR no existe: %BINLOG_DIR%
    exit /b 1
)

:: ================================
:: AUTENTICACION MYSQL
:: ================================

set MYSQL_AUTH=-u %MYSQL_USER%
if not "%MYSQL_PASSWORD%"=="TU_PASSWORD" (
    set MYSQL_AUTH=%MYSQL_AUTH% -p%MYSQL_PASSWORD%
)

:: Generar fecha para el respaldo
for /f %%I in ('powershell -NoProfile -Command "Get-Date -Format \"yyyy-MM-dd_HH-mm\""') do set DATE=%%I
set OUTPUT_FILE=%BACKUP_DIR%\horarios_incremental_%DATE%.sql

:: Leer ultimo binlog y posicion respaldada
set LAST_BINLOG=
set LAST_POSITION=
if exist "%LOG_TRACK_FILE%" (
    for /f "usebackq tokens=1,2 delims=," %%A in ("%LOG_TRACK_FILE%") do (
        set "LAST_BINLOG=%%A"
        set "LAST_POSITION=%%B"
    )
    echo Último binlog respaldado: %LAST_BINLOG% en la posición %LAST_POSITION%.
) else (
    echo No se encontró un registro previo de binlogs respaldados.
)

:: Obtener el binlog actual
%MYSQL_CLI_BIN% %MYSQL_AUTH% -Nse "SHOW MASTER STATUS;" > "%MASTER_STATUS_FILE%"
if errorlevel 1 (
    echo ERROR: No se pudo obtener SHOW MASTER STATUS.
    exit /b 1
)

:: Procesar master_status para obtener binlog y posicion
for /f "usebackq tokens=1,2" %%A in ("%MASTER_STATUS_FILE%") do (
    set "CURRENT_BINLOG=%%A"
    set "CURRENT_POSITION=%%B"
    goto :continue
)

:continue
:: Limpiar espacios adicionales en las variables
set "CURRENT_BINLOG=%CURRENT_BINLOG: =%"
set "CURRENT_POSITION=%CURRENT_POSITION: =%"

if "%CURRENT_BINLOG%"=="" (
    echo ERROR: No se pudo leer el binlog actual.
    exit /b 1
)

echo Binlog actual: %CURRENT_BINLOG%, posición: %CURRENT_POSITION%.

:: Respaldo incremental
if "%LAST_BINLOG%"=="" (
    echo Entrando en caso: No hay un binlog previo respaldado.
    %MYSQL_BINLOG_BIN% "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%OUTPUT_FILE%"
    echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
) else (
    if "%LAST_BINLOG%"=="%CURRENT_BINLOG%" (
        if not "%LAST_POSITION%"=="" (
            echo Entrando en caso: Respaldo incremental desde la posición %LAST_POSITION%.
            %MYSQL_BINLOG_BIN% --start-position=%LAST_POSITION% "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%OUTPUT_FILE%"
            echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
        ) else (
            echo Entrando en caso: Mismo binlog pero sin posicion previa valida.
            %MYSQL_BINLOG_BIN% "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%OUTPUT_FILE%"
            echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
        )
    ) else (
        echo Entrando en caso: Nuevo binlog detectado.
        %MYSQL_BINLOG_BIN% "%BINLOG_DIR%\%CURRENT_BINLOG%" > "%OUTPUT_FILE%"
        echo %CURRENT_BINLOG%,%CURRENT_POSITION% > %LOG_TRACK_FILE%
    )
)

if errorlevel 1 (
    echo ERROR: Fallo la generacion del respaldo incremental.
    exit /b 1
)

:: Mostrar la ruta utilizada para mysqlbinlog
echo Ruta del binlog procesado: "%BINLOG_DIR%\%CURRENT_BINLOG%"
echo Respaldo incremental completado.
echo Archivo generado: "%OUTPUT_FILE%"
